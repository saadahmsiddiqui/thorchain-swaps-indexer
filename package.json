{
  "name": "thorchain-indexer",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "run:server": "ts-node -r tsconfig-paths/register src/server.ts",
    "run:catch-up": "ts-node -r tsconfig-paths/register src/catch-up.ts",
    "run:process-indexed-txs": "ts-node -r tsconfig-paths/register src/process-indexed-txs.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@types/node-schedule": "^2.1.8",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "moment": "^2.30.1",
    "node-schedule": "^2.1.1",
    "pg": "^8.20.0",
    "winston": "^3.19.0"
  }
}
